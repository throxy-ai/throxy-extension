{
  "manifest_version": 3,
  "name": "Throxy Extension",
  "version": "1.9.2",
  "description": "Keyboard shortcuts, time block enforcement, headset mic enforcement, LinkedIn prospect viewer, cal.com timezone/email validation, and more for Throxy SDR operations.",
  "update_url": "https://throxy-extension.throxy.ai/updates.xml",
  "incognito": "spanning",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*.linkedin.com/*", "*://leadflow.throxy.com/*", "*://api.bounceban.com/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "linkedin_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://phone.cloudtalk.io/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.cal.com/*"
      ],
      "js": ["cal-notes-blocker.js", "cal-timezone-checker.js", "cal-email-validator.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
